# LLM Provider configuration: 'gemini', 'openrouter', or 'ollama'
LLM_PROVIDER=openrouter

# Ollama (local, free, no API key needed)
# Download from https://ollama.com/download then run: ollama pull llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
DEFAULT_GEMINI_MODEL=gemini-2.0-flash-lite

# OpenRouter Configuration
# Get a key from https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.5-flash

# Google Gemini API configuration
# Obtain from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# GitHub Personal Access Token (PAT)
# Needs repo read/write access (Contents read, Issues read/write)
GITHUB_PAT=your_github_pat_here

# Default repository to operate on in format 'owner/repo'
GITHUB_REPOSITORY=owner/repo

# JWT Secret Key (generate a secure random key for production)
SECRET_KEY=devassist-super-secret-key-change-in-prod
ACCESS_TOKEN_EXPIRE_MINUTES=60
